{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Baudrun",
  "version": "0.9.5-beta.5",
  "identifier": "io.github.packetThrower.Baudrun",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Baudrun",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#1d1d1d"
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: ipc: http://ipc.localhost https://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob: https:; connect-src 'self' tauri: ipc: http://ipc.localhost https://ipc.localhost https://api.github.com https://github.com https://*.githubusercontent.com https://objects.githubusercontent.com; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/packetThrower/Baudrun/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVDM0ExREQ0NjI1NjBDM0MKUldROERGWmkxQjA2N08zdEgxQzRrcUxzT055STF1ZnowbXIwdnZLOXhvOXpZWEFEZ242aTFFZy8K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright © 2026 Will Lehnertz",
    "category": "Utility",
    "shortDescription": "A serial terminal for network devices.",
    "longDescription": "Baudrun is a cross-platform serial terminal for interacting with network devices like switches, routers, and console servers.",
    "homepage": "https://github.com/packetThrower/Baudrun",
    "licenseFile": "../LICENSE",
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "deb": {
        "depends": [
          "libgtk-3-0 | libgtk-3-0t64",
          "libwebkit2gtk-4.1-0",
          "libusb-1.0-0"
        ],
        "files": {
          "/usr/lib/udev/rules.d/60-baudrun-serial.rules": "../packaging/linux/60-baudrun-serial.rules"
        },
        "postInstallScript": "../packaging/linux/baudrun-postinstall.sh",
        "postRemoveScript": "../packaging/linux/baudrun-postinstall.sh"
      },
      "rpm": {
        "depends": [
          "gtk3",
          "webkit2gtk4.1",
          "libusbx"
        ],
        "files": {
          "/usr/lib/udev/rules.d/60-baudrun-serial.rules": "../packaging/linux/60-baudrun-serial.rules"
        },
        "postInstallScript": "../packaging/linux/baudrun-postinstall.sh",
        "postRemoveScript": "../packaging/linux/baudrun-postinstall.sh"
      },
      "appimage": {
        "bundleMediaFramework": true,
        "files": {
          "/usr/lib/udev/rules.d/60-baudrun-serial.rules": "../packaging/linux/60-baudrun-serial.rules"
        }
      }
    }
  }
}
