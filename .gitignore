# Rust build artifacts. Single-crate layout at repo root, so cargo
# puts everything under target/.
/target/

# Standalone Cargo workspace for the virtual-serial dev test rig.
# Lives in its own subdir so contributors don't pay the main crate's
# gpui / wgpu / alacritty_terminal compile cost just to use the
# pty bridge — but that means its build output lands here rather
# than under /target/, so it needs its own ignore.
scripts/virtual-serial/target/

# Same story for the transfer-tests harness — standalone workspace
# next to virtual-serial that drives Baudrun's send paths against
# the bridge for end-to-end automation.
scripts/transfer-tests/target/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Claude Code working files — local settings, ephemeral worktrees, and the
# launch config that's normally machine-specific. Entire dir hidden to
# keep the repo from accumulating per-machine state.
.claude/

# Private planning + design notes kept locally; not part of the public
# repo. Add new private docs above this block.
DESIGN.md
DESIGN.json
PRODUCT.md
OPENSOURCE_PREP.md

# Local scratch / fixture dir for manual JSON import tests
# (highlight packs, skins, …). Kept out of the repo since the
# contents are throwaway and the schema lives in docs/examples/.
/test/

# Logs & temp
*.log
*.tmp
