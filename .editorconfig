root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.go]
indent_style = tab

[Makefile]
indent_style = tab

[*.{ts,tsx,js,jsx,svelte,json,yml,yaml,css,html,md}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
