{
  "id": "graphite-teal-example",
  "name": "Graphite Teal (Example)",
  "description": "Neutral dark grays with a teal accent — reference skin with every option set.",
  "supportsLight": false,
  "vars": {
    "--font-ui": "-apple-system, BlinkMacSystemFont, \"Inter\", system-ui, sans-serif",
    "--font-mono": "\"JetBrains Mono\", \"SF Mono\", Menlo, ui-monospace, monospace",
    "--font-size-base": "13px",
    "--font-size-label": "11px",
    "--font-size-section": "15px",
    "--font-size-h1": "24px",
    "--label-transform": "uppercase",
    "--label-letter-spacing": "0.04em",
    "--label-weight": "500",

    "--bg-window": "rgba(20, 22, 26, 0)",
    "--bg-sidebar": "rgba(255, 255, 255, 0.03)",
    "--bg-main": "rgba(22, 26, 30, 0.7)",
    "--bg-panel": "rgba(255, 255, 255, 0.05)",
    "--bg-hover": "rgba(255, 255, 255, 0.07)",
    "--bg-active": "rgba(78, 184, 172, 0.22)",
    "--bg-input": "rgba(255, 255, 255, 0.06)",
    "--bg-input-focus": "rgba(255, 255, 255, 0.10)",
    "--bg-terminal": "#16191e",

    "--option-bg": "#22272e",
    "--option-fg": "#d7dde6",
    "--option-group-fg": "#8a94a0",

    "--fg-primary": "rgba(255, 255, 255, 0.92)",
    "--fg-secondary": "rgba(255, 255, 255, 0.62)",
    "--fg-tertiary": "rgba(255, 255, 255, 0.40)",

    "--border-subtle": "rgba(255, 255, 255, 0.07)",
    "--border-strong": "rgba(255, 255, 255, 0.14)",
    "--input-border-idle": "transparent",
    "--panel-border": "none",
    "--sidebar-divider": "1px solid rgba(255, 255, 255, 0.08)",

    "--accent": "#4eb8ac",
    "--accent-hover": "#62ccc0",
    "--danger": "#ff6b6b",
    "--success": "#4ecdc4",
    "--warn": "#f5c572",

    "--radius-sm": "4px",
    "--radius-md": "6px",
    "--radius-lg": "10px",
    "--shadow-panel": "none",
    "--shadow-floating": "0 8px 24px rgba(0, 0, 0, 0.35)",
    "--blur-strength": "0px",

    "--shell-padding": "0",
    "--shell-gap": "0",
    "--panel-radius": "0",
    "--panel-shadow": "none",
    "--titlebar-height": "38px",

    "--scrollbar-thumb": "rgba(255, 255, 255, 0.16)",
    "--scrollbar-thumb-hover": "rgba(255, 255, 255, 0.28)"
  }
}
