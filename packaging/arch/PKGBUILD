# Maintainer: Will Lehnertz <wlehnertz@otec.coop>
pkgname=seriesly-bin
_tag=2026.04.18-4
# Arch pkgver can't contain '-'; swap to .r<n> (AUR convention for
# upstream tags with a release suffix). 2026.04.18-4 -> 2026.04.18.r4
pkgver="${_tag//-/.r}"
pkgrel=1
pkgdesc="A serial terminal for network devices"
arch=('x86_64' 'aarch64')
url="https://github.com/otec-it/Seriesly"
license=('custom:unknown')
depends=('gtk3' 'webkit2gtk-4.1')
conflicts=('seriesly')
provides=("seriesly=${pkgver}")
options=(!strip)

source_x86_64=("seriesly-${_tag}-amd64.deb::${url}/releases/download/${_tag}/seriesly_${_tag}_amd64.deb")
source_aarch64=("seriesly-${_tag}-arm64.deb::${url}/releases/download/${_tag}/seriesly_${_tag}_arm64.deb")
# Replace with real sums when updating:
#   sha256sum seriesly_*.deb
sha256sums_x86_64=('SKIP')
sha256sums_aarch64=('SKIP')

package() {
    cd "${srcdir}"
    # .deb is an ar archive containing data.tar.{gz,xz,zst}. bsdtar
    # reads both ar format and the inner compression, so a two-stage
    # pipe extracts the payload directly into ${pkgdir}.
    bsdtar -xOf seriesly-${_tag}-*.deb 'data.tar.*' | bsdtar -xf - -C "${pkgdir}"
}
